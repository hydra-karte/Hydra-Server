# Datenbank-Enstellungen
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_USER=hydra
DATABASE_PASS= # Erstelle ein sicheres Passwort: openssl rand -base64 32
DATABASE_NAME=hydra

# Sicherheitseinstellungen
# Das AUTH_SECRET ist ein geheimer Schlüssel, der für die Verschlüsselung von Daten und die Generierung von Tokens verwendet wird. 
# Erstellen Sie einen sicheren Schlüssel mit: openssl rand -base64 48
# Dieser Schlüssel darf nach Erstellung nicht geändert werden!
AUTH_SECRET= # Erstelle ein sicheren Schlüssel

# URL der Hydra-Instanz
# Hier muss eine gültige URL eingetragen werden, unter der die Hydra-Instanz aus dem Internet erreichbar sein wird.
# Die URL muss mit http:// oder https:// beginnen und darf keinen Pfad enthalten (z.B. https://example.com, nicht https://example.com/hydra).
INSTANCE_URL=https://example.com




# Optional: Instanznamen
# Diese Einstellungen kannst du auch über das Web-Interface konfigurieren
# INTERNAL_INSTANCENAME=Hydranten SG Beispielhausen # Interner Name, z.B. für die Anzeige in der App
# CLOUD_INSTANCENAME=SG Beispielhausen # Öffentlicher Name für die Anzeige auf der Cloud


# Optional: E-Mail-Einstellungen
# Diese Einstellungen kannst du auch über das Web-Interface konfigurieren
# MAIL_ENABLED=true
# SMTP_SECURE=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=from@example.com


